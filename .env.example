# ============================================
# Pulso ERP - Configuración de Entorno
# ============================================
# Copia este archivo a .env y completa los valores reales.
#
#   cp .env.example .env
#
# IMPORTANTE: El archivo .env NUNCA se sube a Git (ya está en .gitignore).
# Para más detalles, consulta SETUP.md

# ---- GEMINI AI (Opcional) ----
# Clave API de Google Gemini para parseo de documentos con IA.
# Obtén una en: https://aistudio.google.com/apikey
# Si no la configuras, el importador de documentos funcionará sin IA.
GEMINI_API_KEY="TU_GEMINI_API_KEY"

# ---- FIREBASE AUTH (CLIENT) ----
# Crea tu propio proyecto en https://console.firebase.google.com
# Ve a Project Settings > General > Your apps > Web app
# Reemplaza TODOS estos valores con los de TU proyecto.
# Instrucciones detalladas en SETUP.md sección "Paso 1: Firebase"
VITE_FIREBASE_API_KEY="TU_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="tu-proyecto.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="tu-proyecto-id"
VITE_FIREBASE_STORAGE_BUCKET="tu-proyecto-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxxxxxx"
VITE_FIREBASE_MEASUREMENT_ID=""

# ---- FIREBASE ADMIN (SERVIDOR) ----
# Necesario para verificar tokens de autenticación en el backend.
#
# Opción A (Recomendada): Ruta al archivo JSON descargado desde:
#   Firebase Console > Project Settings > Service Accounts > Generate New Private Key
#   Guarda ese archivo en la raíz del proyecto como "firebase-service-account.json"
#   (¡NUNCA lo subas a Git! Ya está en .gitignore)
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"
#
# Opción B: Variable de entorno estándar de Google Cloud (si ya la tienes configurada)
# GOOGLE_APPLICATION_CREDENTIALS="/ruta/absoluta/a/tu/clave.json"

# ---- SERVIDOR ----
PORT="3000"
CORS_ORIGIN="http://localhost:3000"
# Cambia al dominio de producción al desplegar, ej: "https://tu-erp.dominio.com"
# Puedes poner múltiples orígenes separados por coma:
# CORS_ORIGIN="https://tu-erp.dominio.com,https://otro-dominio.com"

# ---- INVENTARIO ----
# Umbral global de stock bajo (por defecto 10).
# Cada producto puede tener su propio stockMinimo que sobreescribe este valor.
LOW_STOCK_THRESHOLD="10"

# ---- POSTGRESQL ----
# Configuración de la base de datos PostgreSQL.
# Puedes usar una base local (ej. instalada con Homebrew, apt, etc.)
# o un servicio como Supabase, Neon, Railway, Render, etc.
#
# Ejemplo con Supabase:
#   SQL_HOST="db.tu-proyecto.supabase.co"
#   SQL_USER="postgres.tu-proyecto"
#   SQL_PASSWORD="tu-password-de-supabase"
#   SQL_DB_NAME="postgres"
#   SQL_SSL="true"
SQL_HOST="localhost"
SQL_USER="postgres"
SQL_PASSWORD="tu_password_seguro"
SQL_DB_NAME="pulso_erp"
SQL_SSL="false"