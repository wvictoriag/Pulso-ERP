# ============================================
# Pulso ERP - Configuración de Entorno
# ============================================
# Copia este archivo a .env.local y completa los valores reales.
#
# cp .env.example .env.local
#

# ---- GEMINI AI ----
# Clave API de Google Gemini para parseo de documentos con IA.
# Obtén una en: https://aistudio.google.com/apikey
GEMINI_API_KEY="TU_GEMINI_API_KEY"

# ---- FIREBASE AUTH (CLIENT) ----
# Crea tu propio proyecto en https://console.firebase.google.com
# Ve a Project Settings > General > Your apps > Web app
# Reemplaza TODOS estos valores con los de TU proyecto.
VITE_FIREBASE_API_KEY="TU_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="tu-proyecto.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="tu-proyecto-id"
VITE_FIREBASE_STORAGE_BUCKET="tu-proyecto-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxxxxxx"
VITE_FIREBASE_MEASUREMENT_ID=""

# ---- FIREBASE ADMIN ----
# Descarga el JSON de credenciales desde:
# Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Coloca la ruta al archivo descargado aquí.
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# ---- SERVIDOR ----
PORT="3000"
CORS_ORIGIN="http://localhost:3000"
# Cambia al dominio de producción al desplegar, ej: "https://tu-erp.dominio.com"
# Puedes poner múltiples orígenes separados por coma:
# CORS_ORIGIN="https://tu-erp.dominio.com,https://otro-dominio.com"

# ---- INVENTARIO ----
# Umbral global de stock bajo (por defecto 10).
# Cada producto puede tener su propio stockMinimo.
LOW_STOCK_THRESHOLD="10"

# ---- POSTGRESQL ----
SQL_HOST="localhost"
SQL_USER="postgres"
SQL_PASSWORD="tu_password_seguro"
SQL_DB_NAME="pulso_erp"
